#!/usr/bin/env bash
set -euo pipefail

# Fast, always-green-able gates that the CI also enforces. Run `just setup`
# once per clone to install this hook (it sets core.hooksPath = .githooks).
#
# `cargo test --workspace` is intentionally NOT run here: the suite carries
# committed-failing TDD tests for subcommands still under construction, so it is
# red by design and cannot gate every commit. CI still runs the full test job.

echo "==> pre-commit: cargo fmt --check"
cargo fmt --all -- --check

echo "==> pre-commit: cargo clippy"
cargo clippy --workspace --lib --bins -- -D warnings

echo "==> pre-commit: all checks passed"
